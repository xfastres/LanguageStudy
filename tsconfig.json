{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@linguaflow/shared": ["./packages/shared/src"],
      "@linguaflow/database": ["./packages/database/src"],
      "@linguaflow/logger": ["./packages/logger/src"]
    }
  },
  "exclude": ["node_modules", "dist", ".next"]
}
